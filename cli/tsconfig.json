{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["bin/**/*.ts", "commands/**/*.ts", "checks/**/*.ts", "reporters/**/*.ts", "config/**/*.ts", "types.ts"],
  "exclude": ["node_modules", "dist"]
}
